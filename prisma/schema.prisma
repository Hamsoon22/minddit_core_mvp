generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @default(cuid())
  name      String
  email     String    @unique
  password  String
  role      Role      @default(PROFESSIONAL)
  sessions  Session[]
  organizationSetting OrganizationSetting?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

enum Role {
  PROFESSIONAL
  ADMIN
}

model Session {
  id           String          @id @default(cuid())
  title        String
  description  String?
  status       SessionStatus   @default(DRAFT)
  mode         ProgramMode     @default(HYBRID)
  scheduleType ScheduleType    @default(WEEKLY)
  joinCode     String          @unique
  scheduledAt  DateTime?
  startDate    DateTime?
  endDate      DateTime?
  institutionName       String?
  institutionAddress    String?
  institutionDirections String?
  institutionPhone      String?
  institutionEmail      String?
  createdBy    User            @relation(fields: [createdById], references: [id])
  createdById  String
  activities   SessionActivity[]
  schedules    ProgramSchedule[]
  participants Participant[]
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
}

enum ProgramMode {
  IN_PERSON
  ONLINE
  HYBRID
}

enum ScheduleType {
  WEEKLY
  DATE_SPECIFIC
  MONTHLY
}

enum SessionStatus {
  DRAFT
  SCHEDULED
  ACTIVE
  COMPLETED
}

model SessionActivity {
  id          String       @id @default(cuid())
  session     Session      @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sessionId   String
  title       String
  type        ActivityType
  durationMin Int          @default(10)
  content     String?
  order       Int          @default(0)
  createdAt   DateTime     @default(now())
}

enum ActivityType {
  CHECKIN
  POLL
  JOURNAL
  MEDITATION
  BREATHING
  MOVEMENT
  VIDEO
  DISCUSSION
}

model Participant {
  id        String   @id @default(cuid())
  name      String
  email     String?
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sessionId String
  attended  Boolean  @default(false)
  joinedAt  DateTime?
  createdAt DateTime @default(now())
}

model ContentBlock {
  id          String       @id @default(cuid())
  title       String
  description String?
  type        ActivityType
  durationMin Int          @default(10)
  content     String?
  isPublic    Boolean      @default(true)
  scheduleItems ProgramScheduleItem[]
  createdAt   DateTime     @default(now())
}

model ProgramSchedule {
  id        String                @id @default(cuid())
  session   Session               @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sessionId String
  label     String
  date      DateTime?
  month     Int?
  order     Int                   @default(0)
  items     ProgramScheduleItem[]
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt

  @@index([sessionId, order])
}

model ProgramScheduleItem {
  id                  String          @id @default(cuid())
  schedule            ProgramSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  scheduleId          String
  contentBlock        ContentBlock?   @relation(fields: [contentBlockId], references: [id])
  contentBlockId      String?
  titleSnapshot       String
  typeSnapshot        ActivityType
  durationMinSnapshot Int
  contentSnapshot     String?
  order               Int             @default(0)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  @@index([scheduleId, order])
}

model OrganizationSetting {
  id          String   @id @default(cuid())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String   @unique
  name        String?
  description String?
  address     String?
  directions  String?
  phone       String?
  email       String?
  enableEmailNotification Boolean @default(true)
  enableAutoBackup       Boolean @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
